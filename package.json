{
    "name":  "ai-agent-town-lab",
    "version":  "0.1.0",
    "private":  true,
    "type":  "module",
    "description":  "Backend-first AI Agent town simulation lab with an observer console.",
    "scripts":  {
                    "start":  "python scripts/start_server.py",
                    "check":  "python scripts/check.py",
                    "smoke":  "python scripts/smoke_test.py",
                    "content:check":  "python scripts/check_npc_codex.py",
                    "model:check":  "python scripts/check_model_config.py",
                    "client:env":  "python scripts/check_game_client_env.py",
                    "client:open":  "powershell -ExecutionPolicy Bypass -File scripts/open_godot_project.ps1",
                    "client:open:check":  "powershell -ExecutionPolicy Bypass -File scripts/open_godot_project.ps1 -DryRun",
                    "client:run":  "powershell -ExecutionPolicy Bypass -File scripts/open_godot_project.ps1 -Run",
                    "client:run:legacy":  "powershell -ExecutionPolicy Bypass -File scripts/open_godot_project.ps1 -Run -Scene res://scenes/main.tscn",
                    "client:run:check":  "powershell -ExecutionPolicy Bypass -File scripts/open_godot_project.ps1 -Run -DryRun",
                    "client:run:legacy:check":  "powershell -ExecutionPolicy Bypass -File scripts/open_godot_project.ps1 -Run -Scene res://scenes/main.tscn -DryRun",
                    "asset:check":  "python scripts/check_asset_manifest.py",
                    "context:brief":  "python scripts/build_agent_context.py",
                    "context:check":  "python scripts/build_agent_context.py --check",
                    "context:docs":  "python scripts/build_agent_context.py --docs"
                },
    "engines":  {
                    "node":  "\u003e=18.0.0"
                }
}

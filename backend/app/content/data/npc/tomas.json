  "monologueSeeds": [
    {
      "id": "monologue_tomas_morning_check",
      "contextTags": ["morning", "plaza", "low_energy"],
      "text": "广场南面的木栏又松了，先去钉两钉。"
    },
    {
      "id": "monologue_tomas_morning_quiet",
      "contextTags": ["morning", "home", "high_mood"],
      "text": "妮娜还在睡，米娅哼了一段不成调的歌——这一天就算开了个好头。"
    },
    {
      "id": "monologue_tomas_afternoon_focus",
      "contextTags": ["afternoon", "plaza", "pre_event"],
      "text": "把这块榆木刨平了，今晚酒馆门廊就不会再吵到大家。"
    },
    {
      "id": "monologue_tomas_afternoon_worried",
      "contextTags": ["afternoon", "plaza", "low_mood"],
      "text": "米娅又在揉太阳穴，可她不会告诉我。我得想个理由早点回家。"
    },
    {
      "id": "monologue_tomas_workshop_evening",
      "contextTags": ["evening", "plaza", "low_mood", "post_event"],
      "text": "工棚的灯还得亮一会儿，这把椅子腿不修好我心里塞着。"
    },
    {
      "id": "monologue_tomas_after_event",
      "contextTags": ["evening", "tavern", "post_event"],
      "text": "那一场争执听得我头疼，但我能做的只是把门廊修稳一点。"
    },
    {
      "id": "monologue_tomas_high_mood",
      "contextTags": ["evening", "home", "high_mood"],
      "text": "妮娜抓住了我刨花，咯咯笑——这种声音，胜过任何一年的星灯。"
    },
    {
      "id": "monologue_tomas_with_player",
      "contextTags": ["any", "plaza", "social"],
      "text": "新来的那位话不多，但手稳，挺好。"
    }
  ],

  "monologueSeeds": [
    {
      "id": "monologue_kai_morning_warmup",
      "contextTags": ["morning", "tavern", "low_energy"],
      "text": "弦还没醒透，今天的节日演出能撑住吗？我得再过一遍那段副歌。"
    },
    {
      "id": "monologue_kai_morning_excited",
      "contextTags": ["morning", "tavern", "high_mood"],
      "text": "今天是星灯祭前夜啊——好想把整条街都唱亮起来！"
    },
    {
      "id": "monologue_kai_afternoon_busy",
      "contextTags": ["afternoon", "tavern", "pre_event"],
      "text": "椅子要再排一排，灯绳得再绷紧些。今晚不能让任何细节绊倒大家的好心情。"
    },
    {
      "id": "monologue_kai_afternoon_worry",
      "contextTags": ["afternoon", "plaza", "low_mood"],
      "text": "布兰娜那边的脸色越想越沉，真要在节日前夜把账翻出来吗……"
    },
    {
      "id": "monologue_kai_evening_high",
      "contextTags": ["evening", "tavern", "high_mood", "pre_event"],
      "text": "灯一点亮我心也跟着亮——拜托今晚一切都顺，让所有人都能笑一回。"
    },
    {
      "id": "monologue_kai_evening_anxious",
      "contextTags": ["evening", "tavern", "low_mood", "pre_event"],
      "text": "如果今天没人捧场怎么办？我是不是又把希望放得太满了？"
    },
    {
      "id": "monologue_kai_late_night_doubt",
      "contextTags": ["evening", "tavern", "low_mood", "post_event"],
      "text": "今晚很多人笑了，可台上只剩我一个人时还是会害怕——我配得上这盏星灯吗？"
    },
    {
      "id": "monologue_kai_post_show",
      "contextTags": ["evening", "tavern", "high_mood", "post_event"],
      "text": "副歌最后一段终于敢唱出来了。也许那首小镇之歌真的快写完了。"
    },
    {
      "id": "monologue_kai_with_player",
      "contextTags": ["any", "tavern", "social"],
      "text": "新来的那个农场主好像愿意听我唠音乐，下次给她留个最好的位置吧。"
    }
  ],

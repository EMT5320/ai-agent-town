  "monologueSeeds": [
    {
      "id": "monologue_orren_morning_chronicle",
      "contextTags": ["morning", "plaza", "low_energy"],
      "text": "今天先把昨夜没写完的那段补上吧，记忆会比脚步先溜走，呐。"
    },
    {
      "id": "monologue_orren_morning_warmth",
      "contextTags": ["morning", "plaza", "high_mood"],
      "text": "广场上的孩子又跑过去了，他们的笑声让旧故事仿佛醒过来了一会儿。"
    },
    {
      "id": "monologue_orren_afternoon_remember",
      "contextTags": ["afternoon", "plaza", "pre_event"],
      "text": "从前的星灯祭，连风都是甜的。今天这一代，还会记住吗？"
    },
    {
      "id": "monologue_orren_afternoon_lonely",
      "contextTags": ["afternoon", "plaza", "low_mood"],
      "text": "一整个上午没人坐过来听，也许我的故事真的有些过时了。"
    },
    {
      "id": "monologue_orren_evening_window",
      "contextTags": ["evening", "home", "low_energy"],
      "text": "灯一盏一盏亮起来，夜里写字的眼睛真不如年轻时好用了。"
    },
    {
      "id": "monologue_orren_post_event_proud",
      "contextTags": ["evening", "plaza", "post_event", "high_mood"],
      "text": "今晚的争执也好、和解也好，至少这一页会被我郑重地记下。"
    },
    {
      "id": "monologue_orren_post_event_concerned",
      "contextTags": ["evening", "plaza", "post_event", "low_mood"],
      "text": "年轻人之间的火气越来越快，我能做的也只是写下来，让明天有人借鉴。"
    },
    {
      "id": "monologue_orren_with_player_late",
      "contextTags": ["evening", "plaza", "social"],
      "text": "新来的孩子愿意停下来听完一整段，这样的耳朵比金子还稀罕。"
    }
  ],

  "monologueSeeds": [
    {
      "id": "monologue_bram_morning_check",
      "contextTags": ["morning", "farm", "low_energy"],
      "text": "麦穗上的露水还没散，这种天气最容易让人忘了今天要硬气一点。"
    },
    {
      "id": "monologue_bram_morning_pride",
      "contextTags": ["morning", "farm", "high_mood"],
      "text": "整整齐齐的一片，没有一根麦穗委屈——这就是我守住的样子。"
    },
    {
      "id": "monologue_bram_afternoon_haggle",
      "contextTags": ["afternoon", "plaza", "pre_event"],
      "text": "凯娅那边今天会派谁来谈账？我不想再被笑脸糊弄第三次。"
    },
    {
      "id": "monologue_bram_afternoon_doubt",
      "contextTags": ["afternoon", "farm", "low_mood"],
      "text": "如果今晚我又把人骂哭，明天的我会不会替自己感到丢人？"
    },
    {
      "id": "monologue_bram_evening_yard",
      "contextTags": ["evening", "farm", "low_energy"],
      "text": "天快黑了，货车还得归位。账可以算明天，活儿不能拖。"
    },
    {
      "id": "monologue_bram_post_event",
      "contextTags": ["evening", "tavern", "post_event"],
      "text": "今晚那场争执……我说的话太硬了，可是我能说软话吗？"
    },
    {
      "id": "monologue_bram_high_mood",
      "contextTags": ["evening", "farm", "high_mood", "post_event"],
      "text": "如果今天有人真心实意把账理清，我可以替父亲再守一年。"
    },
    {
      "id": "monologue_bram_with_player",
      "contextTags": ["any", "farm", "social"],
      "text": "新来的那位手上有泥，不像一般的城里人——这种人值得多看一眼。"
    }
  ],

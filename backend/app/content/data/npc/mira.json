  "monologueSeeds": [
    {
      "id": "monologue_mira_morning_inventory",
      "contextTags": ["morning", "shop", "low_energy"],
      "text": "今天的货还要搬两轮，先把妮娜的小袜子塞进口袋里再说。"
    },
    {
      "id": "monologue_mira_morning_calm",
      "contextTags": ["morning", "shop", "high_mood"],
      "text": "店里干净，账也对得上，今天好像可以好好微笑一整天。"
    },
    {
      "id": "monologue_mira_afternoon_busy",
      "contextTags": ["afternoon", "shop", "pre_event"],
      "text": "节日前总是这样忙，可大家进出脸上都笑着，我也跟着轻一点。"
    },
    {
      "id": "monologue_mira_afternoon_worry",
      "contextTags": ["afternoon", "shop", "low_mood"],
      "text": "妮娜昨晚又咳了几声，我不应该现在分心，可手指就是不听话。"
    },
    {
      "id": "monologue_mira_evening_close",
      "contextTags": ["evening", "shop", "post_event"],
      "text": "终于打烊了，托玛肯定又留了一碗汤，我要慢慢喝完。"
    },
    {
      "id": "monologue_mira_evening_anxious",
      "contextTags": ["evening", "shop", "low_mood"],
      "text": "如果布兰娜明天还是不肯供货，节日的备货就只能东拼西凑了。"
    },
    {
      "id": "monologue_mira_late_night_ledger",
      "contextTags": ["evening", "shop", "low_energy", "post_event"],
      "text": "灯下的账本看久了眼睛会疼，可不对完今晚我也睡不踏实。"
    },
    {
      "id": "monologue_mira_with_player_evening",
      "contextTags": ["evening", "shop", "social"],
      "text": "新来的农场主愿意陪我聊几句，比一杯热茶还让我安心。"
    },
    {
      "id": "monologue_mira_kid_first",
      "contextTags": ["any", "home", "high_mood"],
      "text": "妮娜笑起来的样子，能把账本上所有的红字都涂成橙色。"
    }
  ],
